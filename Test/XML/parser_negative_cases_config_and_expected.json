{
  "package": "xml_parser_pipeline_test_pack",
  "createdFor": "Parser XML pipeline di import: XPath selector, namespace support, mapping elementi/attributi, ParseError[]",
  "notes": [
    "I casi positivi sono gli stessi del pacchetto wizard XML.",
    "I casi negativi riusano i file XML positivi ma cambiano la TraceDefinition/TraceColumnDefinition per produrre errori controllati.",
    "L'input applicativo va passato come MemoryStream dei byte del file XML indicato.",
    "Gli expectedErrors non impongono nomi esatti di enum: indicano categoria, scope e dettagli minimi da validare.",
    "Per nodeMapping/attributeMapping mancanti, la raccomandazione è estrarre comunque la riga valorizzando la colonna con stringa vuota/null e aggiungere ParseError per il campo mancante. Se la vostra pipeline è fail-fast, adeguate l'asserzione, ma il caso resta necessario."
  ],
  "recommendedParseErrorShape": {
    "type": "InvalidXPath | NamespaceNotResolved | NodeNotFound | AttributeNotFound",
    "scope": "xPathSelector | nodeMapping | attributeMapping",
    "rowIndex": "0-based rispetto al nodeset selezionato, se applicabile",
    "columnName": "nome colonna, se applicabile",
    "path": "XPath o attributo che ha generato l'errore",
    "message": "testo diagnostico utile"
  },
  "negativeTestCases": [
    {
      "id": "ERR01_INVALID_XPATH_SELECTOR",
      "description": "xPathSelector sintatticamente non valido: il parser deve restituire ParseError e non estrarre righe.",
      "fileName": "01_no_namespace_elements_and_attributes.xml",
      "input": {
        "type": "MemoryStream",
        "sourceFile": "01_no_namespace_elements_and_attributes.xml"
      },
      "traceDefinitionParsingParameters": {
        "xPathSelector": "//*[",
        "namespaceSupport": false,
        "namespaceMap": {}
      },
      "traceColumnDefinitions": [
        {
          "columnName": "employee_id",
          "attributeMapping": "id"
        },
        {
          "columnName": "first_name",
          "nodeMapping": "FirstName"
        },
        {
          "columnName": "last_name",
          "nodeMapping": "LastName"
        },
        {
          "columnName": "email",
          "nodeMapping": "Email"
        },
        {
          "columnName": "department",
          "nodeMapping": "Department"
        },
        {
          "columnName": "country",
          "nodeMapping": "Country"
        },
        {
          "columnName": "salary",
          "nodeMapping": "Salary"
        },
        {
          "columnName": "hire_date",
          "nodeMapping": "HireDate"
        },
        {
          "columnName": "active",
          "attributeMapping": "active"
        }
      ],
      "expectedRows": [],
      "expectedErrors": [
        {
          "type": "InvalidXPath",
          "scope": "xPathSelector",
          "path": "//*[",
          "messageContains": [
            "XPath",
            "invalid"
          ]
        }
      ]
    },
    {
      "id": "ERR02_UNRESOLVED_NAMESPACE_PREFIX_IN_SELECTOR",
      "description": "XPath usa prefisso hr ma namespaceMap non lo dichiara.",
      "fileName": "03_prefixed_namespace.xml",
      "input": {
        "type": "MemoryStream",
        "sourceFile": "03_prefixed_namespace.xml"
      },
      "traceDefinitionParsingParameters": {
        "xPathSelector": "//hr:Employees/hr:Employee",
        "namespaceSupport": true,
        "namespaceMap": {}
      },
      "traceColumnDefinitions": [
        {
          "columnName": "employee_id",
          "attributeMapping": "id"
        },
        {
          "columnName": "first_name",
          "nodeMapping": "hr:FirstName"
        }
      ],
      "expectedRows": [],
      "expectedErrors": [
        {
          "type": "NamespaceNotResolved",
          "scope": "xPathSelector",
          "path": "//hr:Employees/hr:Employee",
          "prefix": "hr",
          "messageContains": [
            "hr",
            "namespace"
          ]
        }
      ]
    },
