{
  "package": "xml_wizard_examples",
  "createdFor": "Wizard configurazione tracciati XML con XPath, namespace e mapping elementi/attributi",
  "canonicalColumns": [
    "employee_id",
    "first_name",
    "last_name",
    "email",
    "department",
    "country",
    "salary",
    "hire_date",
    "active"
  ],
  "generalExpectations": [
    "Il parser seleziona il nodeset usando xPathSelector.",
    "Per ogni nodo selezionato, nodeMapping è un XPath relativo al nodo corrente e restituisce il testo dell’elemento selezionato.",
    "attributeMapping legge un attributo XML del nodo corrente selezionato.",
    "Se namespaceSupport=true, XPath selector e nodeMapping devono usare i prefissi dichiarati in namespaceMap.",
    "Nel caso di default namespace, XPath deve comunque usare un prefisso artificiale dichiarato in namespaceMap.",
    "I nodi non selezionati da xPathSelector non devono comparire nell’output.",
    "Campi mancanti o vuoti sono rappresentati come valore vuoto nell’expected CSV."
  ],
  "files": [
    {
      "fileName": "01_no_namespace_elements_and_attributes.xml",
      "description": "XML semplice senza namespace: selector diretto, mapping misto da attributi del nodo Employee e da elementi figli/annidati.",
      "parameters": {
        "xPathSelector": "/Employees/Employee",
        "namespaceSupport": false,
        "namespaceMap": {},
        "columns": [
          {
            "columnName": "employee_id",
            "attributeMapping": "id"
          },
          {
            "columnName": "first_name",
            "nodeMapping": "FirstName"
          },
          {
            "columnName": "last_name",
            "nodeMapping": "LastName"
          },
          {
            "columnName": "email",
            "nodeMapping": "Email"
          },
          {
            "columnName": "department",
            "nodeMapping": "Department"
          },
          {
            "columnName": "country",
            "nodeMapping": "Country"
          },
          {
            "columnName": "salary",
            "nodeMapping": "Compensation/Salary"
          },
          {
            "columnName": "hire_date",
            "nodeMapping": "HireDate"
          },
          {
            "columnName": "active",
            "attributeMapping": "active"
          }
        ]
      },
      "expectedRecordCount": 2,
      "expectedRecords": [
        {
