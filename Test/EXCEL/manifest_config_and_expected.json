{
  "purpose": "Test wizard configurazione tracciati Excel .xlsx con supporto a range semplici e listObject (tabelle strutturate Excel).",
  "startRowConvention": "1-based, come numero di riga Excel. Se assente e listObjectName è null, leggere da A1.",
  "precedenceRules": [
    "Se listObjectName è valorizzato, usare i bounds del listObject indicato dentro lo sheetName.",
    "Se listObjectName è valorizzato, startRow va ignorato/non richiesto.",
    "Se listObjectName è null, leggere da A{startRow}; se startRow è null, leggere da A1.",
    "Con headerPresence=true, usare la prima riga del range/listObject per mapping automatico da header.",
    "Con headerPresence=false, non usare la prima riga come header del tracciato: usare mapping manuale/columnOrder.",
    "Per listObject con headerPresence=false, considerare il data body della tabella e mappare le colonne in ordine secondo columnOrder; la header row Excel resta tecnica."
  ],
  "canonicalOutputColumns": [
    "customer_id",
    "first_name",
    "last_name",
    "email",
    "country",
    "amount",
    "signup_date",
    "active"
  ],
  "totalExpectedRecords": 12,
  "testCases": [
    {
      "id": "01_range_a1_header",
      "fileName": "01_range_a1_header.xlsx",
      "description": "Range semplice da A1 con header canonico. Deve usare sheetName e ignorare gli altri fogli.",
      "config": {
        "sheetName": "Customers",
        "listObjectName": null,
        "headerPresence": true,
        "startRow": null
      },
      "expectedRecordCount": 2,
      "expectedRows": [
        {
          "test_case": "01_range_a1_header",
          "source_file": "01_range_a1_header.xlsx",
          "customer_id": 201,
          "first_name": "Alice",
          "last_name": "Verdi",
          "email": "alice.verdi@example.com",
          "country": "IT",
          "amount": "1200.50",
          "signup_date": "2026-01-15",
          "active": "true"
        },
        {
          "test_case": "01_range_a1_header",
          "source_file": "01_range_a1_header.xlsx",
          "customer_id": 202,
          "first_name": "Bruno",
          "last_name": "Neri",
          "email": "bruno.neri@example.com",
          "country": "IT",
          "amount": "99.90",
          "signup_date": "2026-01-16",
          "active": "false"
        }
      ],
      "notes": [
        "Se listObjectName è assente e startRow è assente, leggere da A1."
      ]
    },
    {
      "id": "02_range_startrow_header",
