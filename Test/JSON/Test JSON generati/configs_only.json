  "semantics": {
    "executionOrder": "rootPath -> nodeSelector -> arraySelector opzionale -> propertyMapping",
    "rootPath": "JSONPath valutato sul documento JSON completo: definisce il contesto iniziale.",
    "nodeSelector": "JSONPath valutato relativamente al risultato di rootPath: seleziona i nodi/oggetti da considerare come record di primo livello.",
    "arraySelector": "Opzionale. Se valorizzato, viene valutato dentro ciascun nodo selezionato da nodeSelector e apre/flattena l’array annidato; ogni elemento dell’array diventa la riga finale.",
    "propertyMapping": "JSONPath relativo all’oggetto finale che diventa riga: il nodo selezionato da nodeSelector se arraySelector è assente, oppure l’elemento dell’array aperto da arraySelector."
  }
