{
  "packageName": "json_wizard_examples",
  "purpose": "Test per wizard di configurazione tracciati JSON con JSONPath/path-driven extraction.",
  "jsonPathDialectAssumption": "Sintassi tipo Jayway/Newtonsoft: $, dot notation, [*], predicati [?(@.field == value)]. Confermare/adattare se la libreria scelta usa varianti diverse.",
  "expectedSemantics": {
    "executionOrder": "rootPath -> nodeSelector -> arraySelector opzionale -> propertyMapping",
    "rootPath": "Valutato sul documento JSON completo; definisce il contesto iniziale.",
    "nodeSelector": "Valutato relativamente al risultato di rootPath; identifica i nodi/oggetti da considerare come record di primo livello. Tipicamente $[*], $, o un filtro.",
    "arraySelector": "Opzionale. Se valorizzato, viene valutato dentro ciascun nodo selezionato da nodeSelector. Serve ad aprire un array annidato; ogni elemento dell’array diventa la riga finale. Se restituisce più array, il parser deve concatenarne/flattenarne gli elementi.",
    "propertyMapping": "JSONPath relativo all’oggetto finale che diventa riga: il nodo selezionato da nodeSelector se arraySelector è assente, oppure l’elemento dell’array aperto da arraySelector.",
    "missingOrNullProperty": "Atteso come valore vuoto/null normalizzato a stringa vuota nell’expected CSV."
  },
  "canonicalColumns": [
    "employee_id",
    "first_name",
    "last_name",
    "email",
    "department",
    "city",
    "country",
    "salary",
    "hire_date",
    "active",
    "source_system"
  ],
  "totalExpectedRows": 15,
