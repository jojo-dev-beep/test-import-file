          }
        },
        {
          "fieldName": "note",
          "source": {
            "headerName": "note"
          }
        }
      ],
      "expected": {
        "rows": [
          {
            "customer_id": "13",
            "first_name": "Valid",
            "last_name": "Row",
            "email": "valid.row@example.com",
            "country": "IT",
            "amount": "12.00",
            "note": "ok"
          }
