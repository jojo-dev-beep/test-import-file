      "file": "07_error_column_count_mismatch_utf8_header_doublequote.csv",
      "parsingParameters": {
        "type": "CSV",
        "delimiter": ",",
        "textQualifier": "\"",
        "encoding": "UTF-8",
        "headerPresence": true
      },
      "traceColumnDefinitions": [
        {
          "fieldName": "customer_id",
